{
  "name": "muvico",
  "private": true,
  "version": "1.4.0",
  "main": "src/index.js",
  "scripts": {
    "start": "docker compose up",
    "stop": "docker compose down",
    "reset": "docker compose down --volumes --remove-orphans",
    "start-prod": "docker compose -f compose.prod.yaml up --build",
    "stop-prod": "docker compose -f compose.prod.yaml down",
    "reset-prod": "docker compose -f compose.prod.yaml down --volumes --remove-orphans",
    "dev": "NODE_ENV=development concurrently --names node,vite 'nodemon --exec node src/server/index.js' 'vite --host'",
    "prod": "NODE_ENV=production node src/server/index.js",
    "lint": "eslint",
    "format": "prettier --write '*.{js,json,css,md}'",
    "test": "jest",
    "test-frontend": "jest --coverage --selectProjects Frontend",
    "test-backend": "jest --coverage --selectProjects Backend",
    "coverage": "jest --coverage && xdg-open coverage/lcov-report/index.html",
    "build": "vite build",
    "e2e": "concurrently --kill-others 'NODE_ENV=test node src/server/index.js' 'vite --host' 'playwright test --project=chromium --ui'",
    "e2e-headless": "concurrently --success command-playwright --kill-others --names node,vite,playwright 'NODE_ENV=test node src/server/index.js' 'vite --host' 'playwright test --project=chromium'",
    "e2e:report": "playwright show-report",
    "prepare": "husky || true"
  },
  "jest": {
    "coverageReporters": [
      "lcov"
    ],
    "projects": [
      {
        "displayName": "Frontend",
        "testMatch": [
          "<rootDir>/src/client/tests/unit/*"
        ],
        "testEnvironment": "jsdom",
        "setupFilesAfterEnv": [
          "<rootDir>/setup-jest.js"
        ],
        "moduleNameMapper": {
          "\\.(css|less|scss|sass)$": "<rootDir>/__mocks__/styleMock.js"
        }
      },
      {
        "displayName": "Backend",
        "preset": "@shelf/jest-mongodb",
        "testMatch": [
          "<rootDir>/src/server/tests/*"
        ]
      }
    ]
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "prettier --write",
      "eslint"
    ],
    "!*.{js,jsx}": "prettier --ignore-unknown --write"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MuViCo/MuViCo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/client-secrets-manager": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@chakra-ui/icons": "^2.2.4",
    "@chakra-ui/react": "^2.8.2",
    "@chakra-ui/theme-tools": "^2.2.6",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@reduxjs/toolkit": "^2.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "axios": "^1.8.3",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase": "^11.4.0",
    "firebase-admin": "^13.2.0",
    "framer-motion": "^12.5.0",
    "googleapis": "^148.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.14.2",
    "mongoose": "^8.12.1",
    "mongoose-unique-validator": "^5.0.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "playwright": "^1.51.0",
    "react": "^19.0.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^1.5.1",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.3.0",
    "redux": "^5.0.1",
    "vite": "^6.2.2",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@eslint/compat": "^1.2.7",
    "@playwright/test": "^1.56.1",
    "@shelf/jest-mongodb": "^4.3.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "aws-sdk-client-mock": "^4.1.0",
    "codecov": "^3.8.3",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.9",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "supertest": "^7.0.0"
  }
}
