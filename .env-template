# Backend port
PORT=8000
# Frontend port for development
VITE_DEV_PORT=3000

# Express jwt secret
SECRET= # Generate your own using python.secrets.token_hex(16)

# Mongodb connection string used when running app
MONGODB_URI=
# Mongodb connection string used when tests
TEST_MONGODB_URI=

# S3 style object storage endpoint
PUBLIC_S3_ENDPOINT=
# object storage bucket
BUCKET_NAME=
# object storage region
BUCKET_REGION=
# object storage access key
ACCESS_KEY= 
# object storage secret access key
SECRET_ACCESS_KEY=

# Project firebase keys
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Backend firebase service account key as base64 encoded json
FIREBASE_SERVICE_KEY=

# Project google keys for Drive integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
